{
  "annotations": { "list": [] },
  "description": "Edge Tasksの構造化JSON logを列として閲覧するDashboard",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Overviewへ戻る",
      "type": "link",
      "url": "https://localhost/grafana/d/edge-tasks-overview/edge-tasks-overview"
    },
    {
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
