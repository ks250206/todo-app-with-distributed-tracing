      },
      "pluginVersion": "12.3.3",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{service_name=\"caddy\"} | json",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Caddy access logs (table)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
