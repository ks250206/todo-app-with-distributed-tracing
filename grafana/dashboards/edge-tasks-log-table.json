      "title": "Prometheusを開く",
      "type": "link",
      "url": "https://localhost/prometheus/"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Service filterで対象を選ぶと、JSON fieldを列として確認できます。",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": true },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [ { "desc": true, "displayName": "Time" } ]
      },
      "pluginVersion": "12.3.3",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{service_name=~\"$service\"} | json",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "All application logs (table)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Caddy access log。header、query parameter、完全なclient IPは収集しません。",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": true },
